generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CLIENT
  WRITER
  ADMIN
}

enum OrderStatus {
  DRAFT
  PENDING
  ASSIGNED
  IN_PROGRESS
  UNDER_REVIEW
  REVISION_REQUESTED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum UrgencyLevel {
  ONE_HOUR
  THREE_HOURS
  SIX_HOURS
  TWELVE_HOURS
  TWENTY_FOUR_HOURS
  CUSTOM
}

enum AcademicLevel {
  HIGH_SCHOOL
  UNDERGRADUATE
  MASTERS
  PHD
  PROFESSIONAL
}

enum PaymentStatus {
  PENDING
  PAID
  ESCROW
  RELEASED
  REFUNDED
  FAILED
}

enum TransactionType {
  PAYMENT
  PAYOUT
  REFUND
  COMMISSION
  DEPOSIT
  WITHDRAWAL
}

enum WriterStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum NotificationType {
  ORDER_ASSIGNED
  ORDER_SUBMITTED
  ORDER_COMPLETED
  ORDER_REVISION
  ORDER_DISPUTE
  PAYMENT_RECEIVED
  PAYMENT_RELEASED
  NEW_MESSAGE
  SYSTEM
  EMERGENCY
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  avatar        String?
  phone         String?
  role          Role     @default(CLIENT)
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  isBanned      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Auth
  passwordHash             String?
  googleId                 String?   @unique
  emailVerificationToken   String?   @unique
  emailVerificationExpires DateTime?
  sessions                 Session[]

  // Client-specific
  clientOrders  Order[]  @relation("ClientOrders")
  wallet        Wallet?
  referralCode  String?  @unique
  referredBy    String?

  // Writer-specific
  writerProfile WriterProfile?

  // Common
  sentMessages     Message[]        @relation("SentMessages")
  notifications    Notification[]
  transactions     Transaction[]
  reviews          Review[]         @relation("ReviewAuthor")
  receivedReviews  Review[]         @relation("ReviewTarget")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model WriterProfile {
  id               String       @id @default(cuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio              String?
  specialization   String?
  specializations  String[]
  education        String?
  experience       Int          @default(0)
  languages        String[]     @default(["English"])
  status           WriterStatus @default(OFFLINE)
  isApproved       Boolean      @default(false)
  isVerified       Boolean      @default(false)
  averageRating    Float        @default(0)
  rating           Float        @default(0)
  totalReviews     Int          @default(0)
  totalOrders      Int          @default(0)
  completedOrders  Int          @default(0)
  currentOrdersCount Int        @default(0)
  onTimeDelivery   Float        @default(0)
  performanceScore Float        @default(0)
  portfolioUrl     String?
  resumeUrl        String?
  idDocumentUrl    String?
  joinedAt         DateTime     @default(now())
  lastActiveAt     DateTime     @default(now())

  orders Order[] @relation("WriterOrders")

  @@map("writer_profiles")
}

model Order {
  id            String       @id @default(cuid())
  orderNumber   String       @unique
  title         String
  description   String       @db.Text
  instructions  String?      @db.Text
  category      String
  academicLevel AcademicLevel
  wordCount     Int
  urgency       UrgencyLevel
  deadline      DateTime
  status        OrderStatus  @default(PENDING)
  isEmergency   Boolean      @default(false)

  // Pricing
  basePrice     Float
  urgencyPrice  Float
  emergencyFee  Float        @default(0)
  totalPrice    Float
  currency      String       @default("NGN")

  // Relations
  clientId      String
  client        User         @relation("ClientOrders", fields: [clientId], references: [id])
  writerId      String?
  writer        WriterProfile? @relation("WriterOrders", fields: [writerId], references: [id])

  // Files
  attachments   OrderFile[]
  submissions   Submission[]

  // Communication
  messages      Message[]

  // Payment
  payment       Payment?

  // Metadata
  revisionCount Int          @default(0)
  maxRevisions  Int          @default(3)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  completedAt   DateTime?
  assignedAt    DateTime?

  reviews       Review[]
  notifications Notification[]

  @@map("orders")
}

model OrderFile {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name      String
  url       String
  size      Int
  mimeType  String
  uploadedAt DateTime @default(now())

  @@map("order_files")
}

model Submission {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  content     String?  @db.Text
  fileUrl     String?
  fileName    String?
  notes       String?
  submittedAt DateTime @default(now())
  isRevision  Boolean  @default(false)
  version     Int      @default(1)

  @@map("submissions")
}

model Message {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  content   String   @db.Text
  fileUrl   String?
  fileName  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("messages")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  clientId        String
  amount          Float
  currency        String        @default("NGN")
  status          PaymentStatus @default(PENDING)
  paystackRef     String?       @unique
  paystackTxRef   String?
  escrowAmount    Float
  commissionAmount Float
  writerAmount    Float
  paidAt          DateTime?
  releasedAt      DateTime?
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance     Float    @default(0)
  totalEarned Float    @default(0)
  totalSpent  Float    @default(0)
  currency    String   @default("NGN")
  updatedAt   DateTime @updatedAt

  @@map("wallets")
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Float
  currency    String          @default("NGN")
  description String
  reference   String?         @unique
  status      PaymentStatus   @default(PENDING)
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@map("transactions")
}

model Review {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  authorId   String
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId   String
  target     User     @relation("ReviewTarget", fields: [targetId], references: [id])
  rating     Int
  comment    String   @db.Text
  createdAt  DateTime @default(now())

  @@map("reviews")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  orderId   String?
  order     Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  metadata  Json?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String   @db.Text
  coverImage  String?
  category    String
  tags        String[]
  author      String
  authorImage String?
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  readTime    Int      @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique
  discount    Float
  isPercent   Boolean  @default(true)
  maxUses     Int      @default(100)
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("promo_codes")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
